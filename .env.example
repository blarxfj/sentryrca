# ─── Application database (pgvector, port 5433) ──────────────────────────────
POSTGRES_USER=sentryrca
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sentryrca
DATABASE_URL=postgresql+asyncpg://sentryrca:change_me@localhost:5433/sentryrca

# ─── Langfuse infrastructure ──────────────────────────────────────────────────
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=change_me
LANGFUSE_DB_NAME=langfuse

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=change_me

REDIS_AUTH=change_me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
LANGFUSE_S3_BUCKET_EVENTS=langfuse-events

# ─── Langfuse app ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=change_me_32_hex_chars
LANGFUSE_SALT=change_me_32_hex_chars
# Generate: openssl rand -hex 32  (must be exactly 64 hex chars / 32 bytes)
LANGFUSE_ENCRYPTION_KEY=change_me_64_hex_chars

NEXTAUTH_URL=http://localhost:3000

LANGFUSE_INIT_ORG_ID=sentryrca-org
LANGFUSE_INIT_ORG_NAME=SentryRCA
LANGFUSE_INIT_PROJECT_ID=sentryrca
LANGFUSE_INIT_PROJECT_NAME=sentryrca
LANGFUSE_INIT_USER_EMAIL=you@example.com
LANGFUSE_INIT_USER_PASSWORD=change_me

# ─── Langfuse SDK (for the Python agent) ─────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ─── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model names are referenced via LiteLLM config; override here if needed.
# LITELLM_MODEL_REASONING=claude-sonnet-4-6
# LITELLM_MODEL_FAST=claude-haiku-4-5-20251001
